{
  "name": "aziface-web",
  "version": "1.0.0",
  "description": "Web SDK adapter for React.",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:packages": "npm run build --workspace=packages --if-present",
    "build:apps": "npm run build --workspace=apps --if-present",
    "build": "npm run build:packages && npm run build:apps",
    "dev": "npm run dev --workspaces --if-present",
    "release": "cd packages/aziface && npm run build && npx semantic-release",
    "clean": "npm run clean --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azifydev/aziface-web.git"
  },
  "keywords": [],
   "author": "Azify (https://github.com/azifydev)",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/azifydev/aziface-web/issues"
  },
  "homepage": "https://github.com/azifydev/aziface-web#readme",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^11.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^11.0.3",
    "@semantic-release/release-notes-generator": "^12.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
